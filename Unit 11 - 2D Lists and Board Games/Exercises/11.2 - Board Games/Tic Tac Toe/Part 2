board = Group()

def initializeGame():
    # Create the board and initialize game properties.
    cellSize = 400 / 3
    for row in range(app.rows):
        for col in range(app.cols):

            # Calculate x, y for each row, col and add a rectangle to
            # the board group.
            y = col * 133.5
            x = row * 133.5
            board.add(Rect(x, y, 133.5, 133.5, fill = 'skyBlue', border = 'lightCyan', borderWidth = 5))
            # Calculate the center of each cell and add a label there.
            # Also assign the label into app.board and add it to the board Group.
            centerX = x + 68.75
            centerY = y + 68.75
            label = Label('', centerX, centerY, size = 90, bold = True)
            app.board[row].insert(col,label)
            board.add(label)


    # The current player: 'O' or 'X'.
    app.player = 'O'

    # The game status.
    app.isGamePlaying = False

