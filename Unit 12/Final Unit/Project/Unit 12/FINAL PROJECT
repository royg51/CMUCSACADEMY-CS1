def onKeyPress(key):
    #checks if the users want to shoot, moves the players, and makes the 
    #instructions screen turn on or off based on the keys the user presses
    if key == "e" and app.gameStart == True and (app.AIMode == "On" or app.PVPMode == "On"):
        app.shootingP1 = True
    else:
        app.shootingP1 = False
    if key == "/" and app.gameStart == True and app.PVPMode == "On":
        app.shootingP2 = True
    else:
        app.shootingP2 = False
    if key == "w" and app.AIMode == "On" and app.gameStart == True and player1right.left >= -2 and player1right.right < 209 and player1right.top > 75 and player1right.bottom <= 415 and instructions.visible == False:
        player1right.centerY -= 10
        gun1.centerX = player1right.centerX + 41
        gun1.centerY = player1right.centerY
    if key == "a" and app.AIMode == "On" and app.gameStart == True  and player1right.left >= 8 and player1right.right < 209 and player1right.top > 60 and player1right.bottom <= 415 and instructions.visible == False:
        player1right.centerX -= 10
        gun1.centerX = player1right.centerX + 41
        gun1.centerY = player1right.centerY
    if key == "d" and app.AIMode == "On" and app.gameStart == True and player1right.left >= -2 and player1right.right < 168 and player1right.top > 60 and player1right.bottom <= 415  and instructions.visible == False:
        player1right.centerX += 10
