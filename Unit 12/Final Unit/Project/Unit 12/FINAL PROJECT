def AddMoreShieldsIfNeeded():
    #if the # of shields don't meet the # of required shields then create
    #more
    for i in range(app.requiredShields):
        if app.numberofShields < app.requiredShields:
            shield = RegularPolygon(100, 65, 20, 5, fill = 'blue') 
            app.numberofShields += 1
            shields.add(shield)
def ShowShields():
    #makes the shields visible and at a random postion
    AddMoreShieldsIfNeeded()
    if app.numberofShields == app.requiredShields and (app.AIMode == "On" or app.PVPMode == "On"):
        for blue in shields.children:
            blue.centerX = randrange(20, 380)
            blue.centerY = randrange(60, 340)
        shields.visible = True
def MoveShields():
    #makes the shields move and if they touch the borders of the canvas they 
    #move back to a random spot
    for extra in shields.children:
        if extra.visible == True and app.gameStart == True and (extra.right < 400 and extra.left > 0 and extra.top > 0 and extra.bottom < 400):
            shields.centerX -= 1
            shields.centerY += 1
        if extra.visible == True and app.gameStart == True and (extra.right > 400 or extra.left < 0 or extra.top < 0 or extra.bottom > 400):
            extra.centerX = randrange(20, 380)
            extra.centerY = randrange(60, 340)
