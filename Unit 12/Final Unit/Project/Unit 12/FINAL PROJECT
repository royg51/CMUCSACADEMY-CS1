def onMousePress(mouseX, mouseY):
    #calls main function 1 if the Computer button on the home screen is clicked
    #calls main function 2 if the Friend button on the home screen is clicked
    #starts the game if either are clicked
    if mouseX > 75 and mouseX < 175 and mouseY <350 and mouseY > 300:
        app.AIMode = "On"
        app.PVPMode = "Off"
        AIMode()
    elif mouseX > 225 and mouseX < 325 and mouseY < 350 and mouseY > 300:
        app.PVPMode = "On"
        app.AIMode ="Off"
        PVPMode()
    if app.AIMode == "On" and mouseX < 270 and mouseX > 130 and mouseY < 390 and mouseY > 360:
        app.gameStart = True
    if app.PVPMode == "On" and mouseX < 270 and mouseX > 130 and mouseY < 390 and mouseY > 360:
        app.gameStart = True
def onStep():
    #calls a lot of the previous helper functions
    #moves the obstacles, shields, checks if any player's health = 0
    #automatically decreases the shield if the player has it
    #automatically moves the AI, and makes it shoot
    #fires the bullets of player 1 and player 2
    #checks if a game is started
    for boulder in obstacles.children:
        if app.gameStart == True:
            boulder.rotateAngle += 5
            if boulder.centerY < 350:
                boulder.centerY += 5
            elif boulder.centerY >= 350:
                boulder.centerY = 50
                boulder.centerX = randrange(50, 350)
    MoveShields()
    CheckGameStart()
