def onKeyHold(keys):
    #controls the car
    if 'w' in keys:
        car.centerY -= 10
    if 's' in keys:
        car.centerY += 10
    if 'a' in keys:
        car.centerX -= 10
def onKeyPress(key):
    #chanes the sky to nightime and removes the snow but still allows you to control
    #the car
    if key == 'n':
        if not(cloud1.fill == 'white' or cloud2.fill == 'white'):
            sky.fill = gradient(rgb(0, 0, 100),rgb(0, 0, 0), start = 'top')
            snow1.clear()
            snow2.clear()
            cloud1.opacity = 100
            cloud2.opacity = 100
