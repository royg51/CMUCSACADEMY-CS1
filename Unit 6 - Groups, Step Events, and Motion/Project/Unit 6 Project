def onStep():
    #makes sure the car stays within the road and resets the snow once it reaches
    #the bottom of the screen
    if car.left >= 400:
        car.left = 0
    elif car.right <= 0:
        car.right = 400
    elif car.bottom >= 321:
        car.bottom = 321
        car.rotateAngle = 0
    elif car.top <= 209:
        car.top = 209
        car.rotateAngle = 0
    else:
        car.centerX += 10
    if snow1.top >= 400:
        snow1.top = 120
    elif snow2.top >= 400:
        snow2.top = 120
    else:
        snow1.centerY += 10
        snow2.centerY += 10
    if snow1 or snow2.hits(snowPile.top, snowPile.centerY) == True:
        if snowPile.top > 317:
            snowPile.top -= 0.2
    if snowPile.top == 317:
        snowPile.top = 317
def onMousePress(mouseX, mouseY):
    #changes the clouds to white and stops everything
    if sky.fill == rgb(140, 195, 255) and cloud1.fill == 'gainsboro':
        cloud1.fill = 'white'
        cloud2.fill = 'white'
        cloud1.opacity = 100
        cloud2.opacity = 100
        app.stepsPerSecond = 0
def onMouseRelease(mouseX, mouseY):
    #changes the clouds back to their original color and reverts everything back to 
    #normal
    if ( not (sky.fill == gradient(rgb(0, 0, 100),rgb(0, 0, 0), start = 'top'))):
        if cloud1.fill == 'white' and cloud2.fill == 'white':
            cloud1.fill = 'gainsboro'
            cloud2.fill = 'gainsboro'
            cloud1.opacity = 95
            cloud2.opacity = 95
            app.stepsPerSecond = 30
