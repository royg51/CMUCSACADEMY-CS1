def ChangeDrillColor():
    #makes it so that the connectors, base, and drill bit change color based on  
    #the base's centerX
    if drillBase.centerX <= 252.5:
        color = 'black'
    else:
        color = 'lightGray'
    drillPart.fill = color
    drillElbowConnector.fill = color
    drillConnector3.fill = color
    drillBase.fill = color
ChangeDrillColor()

#events
def onMousePress(mouseX, mouseY):
    #makes drill bit move based on the mouseX and mouseY as long as it is within
    #the preset range
    #2nd shape (moves based on mouse)
    if mouseX <= 58 and mouseX >= 30 and mouseY <= 344 and mouseY >= 200:
        Part3ofArm.x2 = mouseX
        Part3ofArm.y2 = mouseY - 29.5
        drillPart.centerX = mouseX
        drillPart.centerY = mouseY
def onStep():
    #calculates the distance and angle from the last drill Connector to the actual drill Part, makes the sun move, adjusts the width of 
    #the arm parts based on the strength set, changes the points of the Sun, and
    #also changes the color of the ground based on the position of the Sun
    num1 = distance(drillConnector3.centerX, drillConnector3.centerY, drillPart.centerX, drillPart.top)
    num2 = angleTo(drillConnector3.centerX, drillConnector3.centerY, drillPart.centerX, drillPart.top)
    roundednum1 = rounded(num1)
    roundednum2 = rounded(num2)
    distanceLabel.value = 'Distance: ' + str(roundednum1)
    angleLabel.value = 'Angle: ' + str(roundednum2)
    Sun1.centerX += 1
    Sun.centerX = Sun1.centerX
    if Sun1.left >= 400:
        Sun1.right = 0
    if amountofstrength.value == 0:
        strength = 3
    if amountofstrength.value == 100:
        strength = 8
    if amountofstrength.value == 50:
        strength = 5.5
    Part1ofArm.lineWidth = strength
    Part2ofArm.lineWidth = strength
    Part3ofArm.lineWidth = strength
    if Sun1.centerX <= 200:
        Sun.points = 15
        Sun.numberofPointsonSun = 15
        NumberofPointsOnSun.value = 'Number of points on Sun: ' + str(Sun.numberofPointsonSun)
        groundPart1.fill = 'saddleBrown'
        groundPart2.fill = 'saddleBrown'
        groundPart1.color = 'Brown'
        ColorofGround.value  = 'Color of Ground: ' + groundPart1.color
    elif Sun1.centerX > 200:
        Sun.points = 20
        Sun.numberofPointsonSun = 20
        NumberofPointsOnSun.value = 'Number of points on Sun: ' + str(Sun.numberofPointsonSun)
        groundPart1.fill = 'darkGreen'
        groundPart2.fill = 'darkGreen'
        groundPart1.color = 'Green'
        ColorofGround.value  = 'Color of Ground: ' + groundPart1.color
def onMouseDrag(mouseX, mouseY):
    #moves the slider if the mouse is dragged within the bar
    if mouseX <= 375 and mouseX >= 284 and mouseY < 149 and mouseY > 131:
        slider.centerX = mouseX
        if slider.centerX <= 288:
            amountofstrength.value = 0
        if slider.centerX >= 373:
            amountofstrength.value = 100
        if slider.centerX > 288 and slider.centerX < 373:
            amountofstrength.value = 50
